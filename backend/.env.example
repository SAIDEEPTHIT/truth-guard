# TruthShield backend secrets — copy to .env

# OpenAI (GPT-4o-mini for text + vision)
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google Gemini Flash (FREE tier — text + vision)
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional override; defaults to gemini-2.0-flash with 1.5 fallbacks
GEMINI_TEXT_MODEL=gemini-2.0-flash
GEMINI_VISION_MODEL=gemini-2.0-flash

# HuggingFace Inference API (FREE tier — image classifier ensemble)
# https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=
