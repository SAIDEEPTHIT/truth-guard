{
  "manifest_version": 3,
  "name": "TruthShield",
  "version": "1.0.0",
  "description": "Explainable AI powered browser extension to detect AI-generated content and scam-prone messages.",
  "permissions": ["contextMenus", "activeTab", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": []
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}